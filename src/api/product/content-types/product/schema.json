{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Products"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "name": {
      "type": "string"
    },
    "price": {
      "type": "biginteger"
    },
    "description": {
      "type": "text"
    },
    "brand": {
      "type": "string"
    },
    "weight": {
      "type": "string"
    },
    "stock": {
      "type": "integer"
    },
    "frames": {
      "type": "component",
      "component": "frames.frames",
      "repeatable": true
    },
    "category": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::category.category"
    },
    "Bikes": {
      "type": "component",
      "component": "bikes.bikes",
      "repeatable": true
    }
  }
}
